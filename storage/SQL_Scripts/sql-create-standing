CREATE TABLE Teams(
	Id INTEGER PRIMARY KEY AUTOINCREMENT,
	Season INTEGER,
	City VARCHAR(50),
	Name VARCHAR(50),
	League VARCHAR(20),
	Division VARCHAR(50)
);

CREATE TABLE Results(
	Id INTEGER PRIMARY KEY AUTOINCREMENT,
	TeamId INTEGER NOT NULL,
	Wins INTEGER, 
	Losses INTEGER,
	FOREIGN KEY (TeamId) REFERENCES Teams(Id)
);

-----------------------

CREATE VIEW StandingLocal AS
SELECT Season, Name, League, Division, Wins, Losses
FROM Teams
INNER JOIN Results ON Teams.Id = Results.TeamId
ORDER BY Wins DESC, Losses




