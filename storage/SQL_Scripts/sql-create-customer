SELECT c.Name, o.OrderDate, p.Name 'Product Name', p.Price 'Unit Price',
							(o.Quantity * p.Price) AS 'Total Amount',
							CASE
								WHEN o.PaymentStatus = 0 THEN 'NOT Paid'
								WHEN o.PaymentStatus = 1 THEN 'Paid'
								ELSE 'Contact SysAdmin'
							END AS 'Payment Status'
FROM Orders AS o
JOIN Customers AS c
ON o.CId = c.Id
JOIN Products AS p
ON o.PId = p.Id

--- VIEW ---
CREATE VIEW SalesView
AS
SELECT c.Name, o.OrderDate, p.Name 'Product Name', p.Price 'Unit Price',
							(o.Quantity * p.Price) AS 'Total Amount',
							CASE
								WHEN o.PaymentStatus = 0 THEN 'NOT Paid'
								WHEN o.PaymentStatus = 1 THEN 'Paid'
								ELSE 'Contact SysAdmin'
							END AS 'Payment Status'
FROM Orders AS o
JOIN Customers AS c
ON o.CId = c.Id
JOIN Products AS p
ON o.PId = p.Id

SELECT * FROM SalesView