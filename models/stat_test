import unittest
from models.stat import Stat

class Testing(unittest.TestCase):
    def test_create(self):
        # Arrange
        stat_id = 12
        stat_player = 'testplayer'
        # Act
        stat = Year_Stat(stat_id, stat_player, 2012, 150)
        result = stat
        # Assert
        self.assertEqual(result.id, stat_id)
        self.assertEqual(result.player, stat_player)

    def test_repr_albut(self):
        # Arrange
        stat_player = 'testplayer'
        # Act
        s = Year_Stat(12, stat_player, 'testartist', 'testreleaseyear')
        result = s.__repr__()
        # Assert
        self.assertEqual(stat_player, result)      

unittest.main()
